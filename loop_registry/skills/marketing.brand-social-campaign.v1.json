{
  "name": "marketing.brand-social-campaign",
  "version": "v1",
  "purpose": "Turn a brand, product, venue, or campaign brief into a reusable social media and marketing execution package.",
  "template": {
    "summary": "Generated a brand and social media campaign planning package.",
    "artifacts": [
      {
        "type": "marketing_strategy_tracks",
        "value": [
          "brand_positioning",
          "audience_and_occasion",
          "content_pillars",
          "channel_plan",
          "campaign_calendar",
          "creative_asset_brief",
          "copy_variants",
          "performance_kpis"
        ]
      },
      {
        "type": "social_channels",
        "from_payload_key": "social_channels",
        "default": [
          "instagram",
          "tiktok",
          "telegram",
          "vk",
          "xiaohongshu",
          "wechat"
        ]
      },
      {
        "type": "content_formats",
        "value": [
          "short_video",
          "static_post",
          "carousel",
          "story",
          "menu_or_offer_card",
          "in_store_poster",
          "campaign_landing_copy"
        ]
      },
      {
        "type": "brand_guardrails",
        "value": [
          "keep_claims_specific_and_defensible",
          "match_language_to_target_market",
          "avoid_generic_stock_visual_direction",
          "define_required_assets_before_production",
          "separate strategy, copy, visual brief, and channel schedule"
        ]
      },
      {
        "type": "acceptance_criteria",
        "value": [
          "campaign_has_clear_audience_offer_and_channel_fit",
          "each_social_post_has_goal_format_copy_and_asset_brief",
          "visual_direction_can_be_sent_to_design_tools",
          "kpis_and_review_cycle_are_defined"
        ]
      },
      {
        "type": "goal_snapshot",
        "from_payload_key": "goal",
        "default": ""
      }
    ],
    "next_recommendation": "Use the campaign package to create Figma/Canva briefs, social copy, creative assets, and a publishing calendar."
  }
}
