generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CurrencyCode {
  RUB
  CNY
  USD
}

enum PaymentRequestStatus {
  draft
  submitted
  ocr_pending
  ocr_exception_pending_confirm
  processing
  approved_waiting_payment
  partially_paid
  paid
  rejected
  cancelled
}

model Organization {
  id           String           @id @default(cuid())
  name         String
  taxMode      String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  bankAccounts BankAccount[]
  paymentRequests PaymentRequest[]
}

model BankAccount {
  id             String        @id @default(cuid())
  bankName       String
  accountName    String
  accountNumber  String
  currency       CurrencyCode
  balance        Decimal       @db.Decimal(18, 2)
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  paymentExecutions PaymentExecution[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model PaymentParty {
  id            String           @id @default(cuid())
  name          String
  partyType     String
  bankName      String?
  bankAccount   String?
  contactName   String?
  phone         String?
  paymentRequests PaymentRequest[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model PaymentRequest {
  id               String                @id @default(cuid())
  requestNo        String                @unique
  title            String
  applicantName    String
  requestedAt      DateTime
  purpose          String
  amount           Decimal               @db.Decimal(18, 2)
  paidAmount       Decimal               @default(0) @db.Decimal(18, 2)
  currency         CurrencyCode
  status           PaymentRequestStatus  @default(draft)
  organizationId   String
  paymentPartyId   String
  projectName      String?
  paymentPartyType String
  paymentPartyBank String?
  paymentPartyAccount String?
  isInternal       Boolean               @default(false)
  internalTarget   String?
  flowTemplateId   String?
  flowTemplateName String?
  currentApprovalNode String?
  currentHandler   String?
  ccUsers          Json
  approvalHistory  Json
  ocrStatus        String                @default("not_started")
  attachments      Json
  organization     Organization          @relation(fields: [organizationId], references: [id])
  paymentParty     PaymentParty          @relation(fields: [paymentPartyId], references: [id])
  paymentExecutions PaymentExecution[]
  ledgerEntries    LedgerEntry[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

model PaymentExecution {
  id               String          @id @default(cuid())
  paymentRequestId String
  bankAccountId    String
  amount           Decimal         @db.Decimal(18, 2)
  executedAt       DateTime
  bankReference    String?
  voucherFiles     Json
  note             String?
  executorName     String
  verificationStatus String       @default("pending")
  verificationNote String?
  verifiedBy       String?
  verifiedAt       DateTime?
  paymentRequest   PaymentRequest  @relation(fields: [paymentRequestId], references: [id])
  bankAccount      BankAccount     @relation(fields: [bankAccountId], references: [id])
  createdAt        DateTime        @default(now())
}

model PurchaseRequest {
  id                String   @id
  title             String
  organizationName  String
  projectName       String?
  applicantName     String
  requestedAt       DateTime
  supplierName      String
  purchaseType      String
  content           String
  specification     String
  quantity          Decimal  @db.Decimal(18, 2)
  unit              String
  unitPrice         Decimal  @db.Decimal(18, 2)
  currency          CurrencyCode
  amount            Decimal  @db.Decimal(18, 2)
  purpose           String
  expectedArrivalDate DateTime
  requiresPayment   Boolean  @default(true)
  requiresInventory Boolean  @default(true)
  linkedContractName String?
  status            String
  currentApprovalNode String?
  currentHandler    String?
  approvalHistory   Json
  attachments       Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PurchaseLedger {
  id               String   @id
  purchaseRequestId String
  organizationName String
  supplierName     String
  purchaseType     String
  amount           Decimal  @db.Decimal(18, 2)
  currency         CurrencyCode
  createdAtDate    DateTime
  status           String
  note             String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ContractApproval {
  id                String   @id
  title             String
  organizationName  String
  projectName       String?
  applicantName     String
  requestedAt       DateTime
  contractName      String
  contractNo        String
  contractType      String
  counterpartyName  String
  currency          CurrencyCode
  amount            Decimal  @db.Decimal(18, 2)
  signedAt          DateTime
  effectiveDate     DateTime
  expiryDate        DateTime
  paymentTerms      String
  settlementMethod  String
  summary           String
  status            String
  currentApprovalNode String?
  currentHandler    String?
  ocrStatus         String
  approvalHistory   Json
  attachments       Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ContractLedger {
  id               String   @id
  contractRequestId String
  organizationName String
  contractName     String
  contractNo       String
  counterpartyName String
  amount           Decimal  @db.Decimal(18, 2)
  currency         CurrencyCode
  effectiveDate    DateTime
  expiryDate       DateTime
  status           String
  note             String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LedgerEntry {
  id               String          @id @default(cuid())
  sourceType       String
  sourceNo         String
  organizationName String
  projectName      String?
  businessDate     DateTime
  currency         CurrencyCode
  originalAmount   Decimal         @db.Decimal(18, 2)
  exchangeRate     Decimal         @db.Decimal(18, 6)
  functionalAmount Decimal         @db.Decimal(18, 2)
  direction        String
  accountCode      String
  accountName      String
  summary          String
  paymentRequestId String?
  paymentRequest   PaymentRequest? @relation(fields: [paymentRequestId], references: [id])
  createdAt        DateTime        @default(now())
}

model SystemConfigSnapshot {
  id                    String   @id
  organizations         Json
  departments           Json?
  persons               Json?
  projects              Json?
  ocrRules              Json?
  approvalFlowTemplates Json
  paymentRequestForm    Json
  bankAccounts          Json
  exchangeRates         Json
  ledgerAccountMappings Json
  paymentParties        Json
  roleConfigs           Json?
  userAccounts          Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
